  "doctype": "Print Format",
  "font": null,
  "font_size": 14,
  "format_data": null,
  "html": "<style>\r\n    @page {\r\n        size: A5;\r\n        margin: 10mm 8mm 10mm 8mm;\r\n    }\r\n\r\n    * { box-sizing: border-box; }\r\n\r\n    .print-format {\r\n        font-family: Arial, sans-serif;\r\n        font-size: 7pt;\r\n        color: #1a1a1a;\r\n        line-height: 1.1;\r\n        width: 100%;\r\n        max-width: 100%;\r\n    }\r\n\r\n    .table-main { \r\n        width: 100%; \r\n        border-collapse: collapse; \r\n    }\r\n\r\n    .table-main th {\r\n        background-color: #fcfcfc;\r\n        border-top: 1px solid #000;\r\n        border-bottom: 1px solid #000;\r\n        border-right: 1px solid #ccc;\r\n        padding: 1px 2px;\r\n        text-align: left;\r\n        font-weight: bold;\r\n        text-transform: uppercase;\r\n        font-size: 7pt;\r\n        white-space: nowrap;\r\n    }\r\n\r\n    .table-main th:last-child { border-right: none; }\r\n\r\n    .table-main td { \r\n        padding: 1px 2px; \r\n        border-bottom: 1px solid #bbb;\r\n        border-right: 1px solid #ddd;\r\n        vertical-align: middle;\r\n        white-space: nowrap;\r\n        font-size: 7pt;\r\n    }\r\n\r\n    .table-main td:last-child { border-right: none; }\r\n\r\n    .stone-row td { \r\n        font-size: 8pt; \r\n        font-weight: bold; \r\n        color: #000;\r\n        border-top: 1px solid #000;\r\n    }\r\n\r\n    .moulding-row td { \r\n        color: #555; \r\n        font-style: italic; \r\n        font-size: 7pt;\r\n        border-bottom: 1px solid #ddd;\r\n    }\r\n\r\n    .indent-content { padding-left: 10px !important; }\r\n    .mould-symbol { color: #999; margin-right: 2px; }\r\n\r\n    .edge-box {\r\n        width: 10px; height: 10px; margin: auto; \r\n        background: #fff; border: 0.5px solid #ccc;\r\n    }\r\n\r\n    .summary-box { \r\n        margin-top: 8px; \r\n        display: flex; \r\n        justify-content: flex-end; \r\n    }\r\n\r\n    .summary-table { width: 280px; }\r\n    .summary-table td { \r\n        padding: 0px 0;\r\n        border: none; \r\n        font-size: 8pt;\r\n        line-height: 1.2;\r\n    }\r\n\r\n    .grand-total { \r\n        border-top: 1px solid #000; \r\n        border-bottom: 1px solid #000; \r\n        padding: 4px 0 !important; \r\n        font-size: 10pt; \r\n        font-weight: bold; \r\n    }\r\n\r\n    .sign-grid {\r\n        margin-top: 30px;\r\n        display: flex;\r\n        justify-content: space-between;\r\n        padding-top: 4px;\r\n    }\r\n\r\n    .sign-line {\r\n        width: 110px;\r\n        border-top: 1px solid #000;\r\n        text-align: center;\r\n        padding-top: 2px;\r\n        font-size: 7pt;\r\n    }\r\n</style>\r\n\r\n<!-- HEADER -->\r\n<div style=\"display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid #000; padding-bottom: 4px; margin-bottom: 8px;\">\r\n\r\n    <div style=\"padding: 0 0 0 10;\">\r\n        <div style=\"font-size: 13pt; font-weight: bold;\">\r\n            {{ doc.custom_cash_customer_name if doc.custom_cash_customer_name else doc.customer }}\r\n        </div>\r\n        {% if doc.custom_phone_number %}\r\n        <div style=\"font-size: 7pt; color: #444; margin-top: 2px;\">\r\n            <span style=\"color: #666; font-weight: bold; text-transform: uppercase; font-size: 6.5pt;\">Phone:</span>\r\n            {{ doc.custom_phone_number }}\r\n        </div>\r\n        {% endif %}\r\n    </div>\r\n\r\n    <div style=\"text-align: right; padding: 0 10 0 0;\">\r\n        <div style=\"font-size: 10pt; font-weight: bold; text-transform: uppercase; margin-bottom: 3px;\">Quotation</div>\r\n        <div style=\"font-size: 7pt; line-height: 1.6;\">\r\n            <span style=\"color: #666; font-weight: bold; text-transform: uppercase; font-size: 6.5pt;\">Order No:</span>\r\n            <strong>{{ doc.name[-3:] }}</strong>\r\n        </div>\r\n        <div style=\"font-size: 7pt;\">\r\n            <span style=\"color: #666; font-weight: bold; text-transform: uppercase; font-size: 6.5pt;\">Date:</span>\r\n            {{ doc.get_formatted(\"transaction_date\") }}\r\n        </div>\r\n    </div>\r\n\r\n</div>\r\n<!-- TABLE -->\r\n<table class=\"table-main\">\r\n    <thead>\r\n        <tr>\r\n            <th style=\"width: 18px;\">SR</th>\r\n            <th>Item & Services</th>\r\n            <th style=\"width: 50px;\">Size</th>\r\n            <th style=\"text-align: center; width: 30px;\">Edges</th>\r\n            <th style=\"width: 22px;\">Qty</th>\r\n            <th style=\"width: 65px;\">Measurement</th>\r\n            <th style=\"width: 50px;\">Rate (₹)</th>\r\n            <th style=\"text-align: right; width: 60px;\">Amount (₹)</th>\r\n        </tr>\r\n    </thead>\r\n    <tbody>\r\n        {% set sr_counter = namespace(val=1) %}\r\n        {% set skipped_items = namespace(list=[]) %}\r\n\r\n        {% for item in doc.items %}\r\n            {% if item.name not in skipped_items.list %}\r\n                <tr class=\"stone-row\">\r\n                    <td>{{ sr_counter.val }}</td>\r\n                    <td>{{ item.item_name }}</td>\r\n                    <td style=\"white-space: nowrap;\">{{ item.custom_width|int }} &times; {{ item.custom_height|int }}</td>\r\n                    <td></td>\r\n                    <td>{{ item.custom_quantity|int }}</td>\r\n                    <td>{{ \"%.3f\"|format(item.qty) }} <small>{{ item.uom }}</small></td>\r\n                    <td>{{ \"%.2f\"|format(item.rate) }}</td>\r\n                    <td style=\"text-align: right;\">{{ \"%.2f\"|format(item.amount) }}</td>\r\n                </tr>\r\n                {% set sr_counter.val = sr_counter.val + 1 %}\r\n\r\n                {% for sub in doc.items %}\r\n                    {% if sub.name != item.name and sub.name not in skipped_items.list %}\r\n                        {% if ('Mould' in sub.item_code or 'MouldG' in sub.item_code) and \r\n                               sub.custom_width == item.custom_width and \r\n                               sub.custom_height == item.custom_height %}\r\n\r\n                            {% set _ = skipped_items.list.append(sub.name) %}\r\n                            <tr class=\"moulding-row\">\r\n                                <td></td>\r\n                                <td class=\"indent-content\"><span class=\"mould-symbol\">↳</span>{{ sub.item_name }}</td>\r\n                                <td style=\"font-size: 6.5pt; color: #888; white-space: nowrap;\">{{ sub.custom_width|int }} &times; {{ sub.custom_height|int }}</td>\r\n                                <td>\r\n                                    <div class=\"edge-box\" style=\"\r\n                                        {% if sub.custom_top %} border-top: 2pt solid #000; {% endif %}\r\n                                        {% if sub.custom_bottom %} border-bottom: 2pt solid #000; {% endif %}\r\n                                        {% if sub.custom_left %} border-left: 2pt solid #000; {% endif %}\r\n                                        {% if sub.custom_right %} border-right: 2pt solid #000; {% endif %}\r\n                                    \"></div>\r\n                                </td>\r\n                                <td>{{ sub.custom_quantity|int }}</td>\r\n                                <td>{{ \"%.3f\"|format(sub.qty) }} <small>{{ sub.uom }}</small></td>\r\n                                <td>{{ \"%.2f\"|format(sub.rate) }}</td>\r\n                                <td style=\"text-align: right;\">{{ \"%.2f\"|format(sub.amount) }}</td>\r\n                            </tr>\r\n                        {% endif %}\r\n                    {% endif %}\r\n                {% endfor %}\r\n            {% endif %}\r\n        {% endfor %}\r\n    </tbody>\r\n</table>\r\n\r\n<!-- SUMMARY -->\r\n<div class=\"summary-box\">\r\n    <table style=\"width: 280px; border-collapse: collapse; font-size: 8pt;\">\r\n        <tr>\r\n            <td style=\"font-weight: bold; width: 60%; padding: 0px 0;\">Net Total</td>\r\n            <td style=\"text-align: right; font-weight: bold; width: 40%; padding: 0px 0;\">{{ \"%.2f\"|format(doc.total) }}</td>\r\n        </tr>\r\n        {% for tax in doc.taxes %}\r\n            {% if tax.tax_amount %}\r\n            <tr>\r\n                <td style=\"color: #666; padding: 0px 0;\">{{ tax.description }}</td>\r\n                <td style=\"text-align: right; padding: 0px 0;\">{{ \"%.2f\"|format(tax.tax_amount) }}</td>\r\n            </tr>\r\n            {% endif %}\r\n        {% endfor %}\r\n        <tr>\r\n            <td style=\"border-top: 1px solid #000; border-bottom: 1px solid #000; padding: 3px 0; font-size: 10pt; font-weight: bold;\">GRAND TOTAL</td>\r\n            <td style=\"border-top: 1px solid #000; border-bottom: 1px solid #000; padding: 3px 0; font-size: 10pt; font-weight: bold; text-align: right;\">{{ \"%.2f\"|format(doc.grand_total) }}</td>\r\n        </tr>\r\n    </table>\r\n</div>\r\n\r\n<!-- IN WORDS -->\r\n<div style=\"margin-top: 10px; font-size: 6.5pt; font-style: italic;\">\r\n    <strong>In Words:</strong> {{ doc.in_words }}\r\n</div>\r\n\r\n<!-- SIGNATURE -->\r\n<div class=\"sign-grid\">\r\n    <div class=\"sign-line\">Authorized Signatory</div>\r\n</div>",
