  "html": "<style>\r\n    /* Ultra-Compact Base Styling */\r\n    .print-format {\r\n        font-family: Arial, sans-serif;\r\n        font-size: 8pt;\r\n        color: #1a1a1a;\r\n        line-height: 1.1;\r\n    }\r\n    \r\n    /* Technical Condensed Headings */\r\n    h2 { \r\n        font-family: Arial, sans-serif;\r\n        font-size: 11pt; \r\n        margin: 0; \r\n        font-weight: bold;\r\n        text-transform: uppercase;\r\n    }\r\n    .label { \r\n        color: #666; \r\n        font-weight: bold; \r\n        text-transform: uppercase; \r\n        font-size: 7pt; \r\n    }\r\n    \r\n    /* Header Layout - 3 Column for Centered Status */\r\n    .header-section {\r\n        display: flex; \r\n        justify-content: space-between; \r\n        align-items: flex-end; /* Aligns all text to the bottom line */\r\n        border-bottom: 1px solid #000; \r\n        padding-bottom: 5px;\r\n        margin-bottom: 10px;\r\n    }\r\n\r\n    /* Table Styling */\r\n    .table-main { \r\n        width: 100%; \r\n        border-collapse: collapse; \r\n    }\r\n    .table-main th {\r\n        background-color: #fcfcfc;\r\n        border-top: 1px solid #000;\r\n        border-bottom: 1px solid #000;\r\n        padding: 3px 2px;\r\n        text-align: left;\r\n        font-weight: bold;\r\n        text-transform: uppercase;\r\n        font-size: 8pt;\r\n    }\r\n    .table-main td { \r\n        padding: 2px; \r\n        border-bottom: 1px solid #eee; \r\n        vertical-align: middle; \r\n    }\r\n\r\n    /* Hierarchy Classes */\r\n    .stone-row { font-size: 9pt; font-weight: bold; color: #000; }\r\n    .moulding-row { color: #555; font-style: italic; font-size: 8.5pt; }\r\n    .indent-content { padding-left: 12px !important; }\r\n    .mould-symbol { color: #999; margin-right: 3px; }\r\n\r\n    /* Compact Edge Box */\r\n    .edge-box {\r\n        width: 12px; height: 12px; margin: auto; \r\n        background: #fff; border: 0.5px solid #ccc;\r\n    }\r\n\r\n    /* Increased Width Summary Section */\r\n    .summary-box { \r\n        margin-top: 12px; \r\n        display: flex; \r\n        justify-content: flex-end; \r\n    }\r\n    .summary-table { width: 350px; } /* Increased from 220px to spread columns */\r\n    .summary-table td { padding: 3px 0; border: none; font-size: 9pt; }\r\n    \r\n    .grand-total { \r\n        border-top: 1px solid #000; \r\n        border-bottom: 1px solid #000; \r\n        padding: 6px 0 !important; \r\n        font-size: 11pt; \r\n        font-weight: bold; \r\n    }\r\n\r\n    /* Status Indicator */\r\n    .status-badge {\r\n        font-size: 7.5pt;\r\n        font-weight: bold;\r\n        text-transform: uppercase;\r\n        padding: 1px 6px;\r\n        border: 1px solid #000;\r\n        display: inline-block;\r\n    }\r\n\r\n    .sign-grid { margin-top: 35px; display: flex; justify-content: space-between; }\r\n    .sign-line { width: 130px; border-top: 1px solid #000; text-align: center; padding-top: 2px; font-size: 7.5pt; }\r\n</style>\r\n\r\n<div class=\"header-section\">\r\n    <div style=\"flex: 1.2;\">\r\n        <div style=\"font-size: 11pt; font-weight: bold;\">{{ doc.company }}</div>\r\n        <div style=\"margin-top: 4px;\">\r\n            <span class=\"label\">Client:</span> <strong style=\"font-size: 9pt;\">{{ doc.customer_name }}</strong>\r\n        </div>\r\n    </div>\r\n\r\n    <div style=\"flex: 1; text-align: center; padding-bottom: 2px;\">\r\n        <span class=\"label\" style=\"display: block; margin-bottom: 2px;\">Status</span>\r\n        <span class=\"status-badge\">{{ doc.status }}</span>\r\n    </div>\r\n\r\n    <div style=\"flex: 1.2; text-align: right;\">\r\n        <h2>Sales Order</h2>\r\n        <div style=\"margin-top: 4px;\">\r\n            <span class=\"label\">Order No:</span> <strong>{{ doc.name }}</strong><br>\r\n            <span class=\"label\">Date:</span> {{ doc.get_formatted(\"transaction_date\") }}\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<table class=\"table-main\">\r\n    <thead>\r\n        <tr>\r\n            <th style=\"width: 25px;\">SR</th>\r\n            <th>Item & Services</th>\r\n            <th style=\"width: 70px;\">Size</th>\r\n            <th style=\"text-align: center; width: 45px;\">Edges</th>\r\n            <th style=\"width: 35px;\">Qty</th>\r\n            <th style=\"width: 85px;\">Measurement</th>\r\n            <th style=\"width: 75px;\">Rate</th>\r\n            <th style=\"text-align: right; width: 85px;\">Amount</th>\r\n        </tr>\r\n    </thead>\r\n    <tbody>\r\n        {% set sr_counter = namespace(val=1) %}\r\n        {% set skipped_items = namespace(list=[]) %}\r\n\r\n        {% for item in doc.items %}\r\n            {% if item.name not in skipped_items.list %}\r\n                <tr class=\"stone-row\">\r\n                    <td>{{ sr_counter.val }}</td>\r\n                    <td>{{ item.item_name }}</td>\r\n                    <td>{{ item.custom_width }} &times; {{ item.custom_height }}</td>\r\n                    <td></td>\r\n                    <td>{{ item.custom_quantity }}</td>\r\n                    <td>{{ item.get_formatted(\"qty\") }} <small>{{ item.uom }}</small></td>\r\n                    <td>{{ item.get_formatted(\"rate\", doc) }}</td>\r\n                    <td style=\"text-align: right;\">{{ item.get_formatted(\"amount\", doc) }}</td>\r\n                </tr>\r\n                {% set sr_counter.val = sr_counter.val + 1 %}\r\n\r\n                {% for sub in doc.items %}\r\n                    {% if sub.name != item.name and sub.name not in skipped_items.list %}\r\n                        {% if ('Mould' in sub.item_code or 'MouldG' in sub.item_code) and \r\n                               sub.custom_width == item.custom_width and \r\n                               sub.custom_height == item.custom_height %}\r\n                            \r\n                            {% set _ = skipped_items.list.append(sub.name) %}\r\n                            <tr class=\"moulding-row\">\r\n                                <td></td>\r\n                                <td class=\"indent-content\"><span class=\"mould-symbol\">↳</span>{{ sub.item_name }}</td>\r\n                                <td style=\"font-size: 7.5pt; color: #888;\">{{ sub.custom_width }} &times; {{ sub.custom_height }}</td>\r\n                                <td>\r\n                                    <div class=\"edge-box\" style=\"\r\n                                        {% if sub.custom_top %} border-top: 2pt solid #000; {% endif %}\r\n                                        {% if sub.custom_bottom %} border-bottom: 2pt solid #000; {% endif %}\r\n                                        {% if sub.custom_left %} border-left: 2pt solid #000; {% endif %}\r\n                                        {% if sub.custom_right %} border-right: 2pt solid #000; {% endif %}\r\n                                    \"></div>\r\n                                </td>\r\n                                <td>{{ sub.custom_quantity }}</td>\r\n                                <td>{{ sub.get_formatted(\"qty\") }} <small>{{ sub.uom }}</small></td>\r\n                                <td>{{ sub.get_formatted(\"rate\", doc) }}</td>\r\n                                <td style=\"text-align: right;\">{{ sub.get_formatted(\"amount\", doc) }}</td>\r\n                            </tr>\r\n                        {% endif %}\r\n                    {% endif %}\r\n                {% endfor %}\r\n            {% endif %}\r\n        {% endfor %}\r\n    </tbody>\r\n</table>\r\n\r\n<div class=\"summary-box\">\r\n    <table class=\"summary-table\">\r\n        <tr>\r\n            <td style=\"font-weight: bold; width: 60%;\">Net Total</td>\r\n            <td style=\"text-align: right; font-weight: bold; width: 40%;\">{{ doc.get_formatted(\"total\", doc) }}</td>\r\n        </tr>\r\n        {% for tax in doc.taxes %}\r\n            {% if tax.tax_amount %}\r\n            <tr>\r\n                <td style=\"color: #666;\">{{ tax.description }}</td>\r\n                <td style=\"text-align: right;\">{{ tax.get_formatted(\"tax_amount\", doc) }}</td>\r\n            </tr>\r\n            {% endif %}\r\n        {% endfor %}\r\n        <tr>\r\n            <td class=\"grand-total\">GRAND TOTAL</td>\r\n            <td class=\"grand-total\" style=\"text-align: right;\">{{ doc.get_formatted(\"grand_total\", doc) }}</td>\r\n        </tr>\r\n    </table>\r\n</div>\r\n\r\n<div style=\"margin-top: 5px; font-size: 7.5pt; font-style: italic;\">\r\n    <strong>In Words:</strong> {{ doc.in_words }}\r\n</div>\r\n\r\n<div class=\"sign-grid\">\r\n    <div class=\"sign-line\">Customer Signature</div>\r\n    <div class=\"sign-line\">Authorized Signatory</div>\r\n</div>",
